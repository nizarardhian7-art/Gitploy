<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Theme utama GitDeploy — extends AppCompat agar ViewModelProvider,
        Fragment, dan Navigation Component bisa dipakai.

        Tampilan tetap identik dengan Theme.NoTitleBar yang lama:
          - ActionBar di-hide via windowNoTitle + windowActionBar false
          - Warna system UI (status bar, nav bar) diatur programatik
            oleh ThemeManager.init() di MainActivity.onCreate()
    -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <!-- Background hitam — cocok dengan ThemeManager.BG (#0D0D0F) -->
        <item name="android:windowBackground">@android:color/black</item>

        <!-- Warna status bar &amp; nav bar diatur ThemeManager, bukan di sini -->
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>

        <!-- Tidak ada title bar -->
        <item name="android:windowNoTitle">true</item>

        <!-- Fullscreen input mode — supaya keyboard tidak dorong layout -->
        <item name="android:windowSoftInputMode">adjustResize</item>
    </style>

</resources>
